# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust as needed:
#
#   cp .env.example .env
#
# The dev orchestrator (`pnpm dev` / scripts/dev.mjs) loads this file
# automatically. For other commands (e.g. db push) export the vars first:
#
#   set -a; source .env; set +a
# ---------------------------------------------------------------------------

# PostgreSQL connection string. Matches the bundled docker-compose.yml.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/media_planner

# Port for the Express API server.
API_PORT=8080

# Port for the Vite dev server (frontend).
WEB_PORT=5173

# Log level for the API server (trace | debug | info | warn | error | fatal).
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Object storage (file uploads) — OPTIONAL.
# The calendar / content features work without this. Uploads use Replit's
# Object Storage sidecar by default and require these vars to be set.
# On a public deployment you would swap lib/objectStorage.ts for your own
# S3/GCS credentials.
# ---------------------------------------------------------------------------
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=
